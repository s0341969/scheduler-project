@page
@model RemoteDesktop.Host.Pages.LoginModel
@{
    ViewData["Title"] = "登入";
}

<div class="login-wrap">
    <section class="login-panel">
        <p class="eyebrow">Admin Login</p>
        <h1>登入遠端桌面控制台</h1>
        <p class="subtitle">這個 Control Server 針對產品化部署設計。請先修改預設管理密碼與 Agent 共用金鑰，再投入實際內網環境。</p>

        <form method="post" class="login-form">
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <p class="login-alert">@Model.ErrorMessage</p>
            }

            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="field-stack">
                <label asp-for="Input.UserName"></label>
                <input asp-for="Input.UserName" autocomplete="username" />
                <span asp-validation-for="Input.UserName" class="field-validation-error"></span>
            </div>

            <div class="field-stack">
                <label asp-for="Input.Password"></label>
                <input asp-for="Input.Password" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
            </div>

            <button type="submit" class="login-button">進入控制台</button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
