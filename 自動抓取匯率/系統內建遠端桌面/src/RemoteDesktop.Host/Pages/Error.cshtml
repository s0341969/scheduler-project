@page
@model RemoteDesktop.Host.Pages.ErrorModel
@{
    ViewData["Title"] = "系統錯誤";
}

<section class="error-panel">
    <p class="eyebrow">System Fault</p>
    <h1>控制台暫時無法處理這個要求</h1>
    <p>請先檢查 MSSQL 連線、Control Server 設定與 Agent 是否正常註冊。</p>

    @if (Model.ShowRequestId)
    {
        <p class="request-id">Request ID: <code>@Model.RequestId</code></p>
    }

    <a class="action-link" asp-page="/Index">返回控制台</a>
</section>
