<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RemoteDesk Control</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RemoteDesktop.Host.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="topbar">
            <a class="brand-mark" asp-page="/Index">
                <span class="brand-square"></span>
                <span>RemoteDesk Control</span>
            </a>
            <nav class="topnav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-page="/Index">裝置</a>
                    <a asp-page="/Logs">上線紀錄</a>
                }
            </nav>
        </header>
        <main class="page-body">
            @RenderBody()
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
