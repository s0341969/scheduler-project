{
  "Database": {
    "Provider": "Sqlite"
  },
  "AutoImport": {
    "Enabled": true,
    "PollIntervalSeconds": 60,
    "NucleiDropPath": "App_Data\\AutoImport\\Nuclei\\incoming",
    "NessusDropPath": "App_Data\\AutoImport\\Nessus\\incoming",
    "ProcessedPath": "App_Data\\AutoImport\\processed",
    "FailedPath": "App_Data\\AutoImport\\failed"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data\\vulnscan-dev.db"
  },
  "LocalAuth": {
    "BootstrapUsers": [
      {
        "Account": "admin",
        "UserName": "系統管理員",
        "Email": "admin@local",
        "RoleName": "Admin",
        "Password": "Admin123!Demo"
      },
      {
        "Account": "secmgr",
        "UserName": "資安主管",
        "Email": "security@local",
        "RoleName": "SecurityManager",
        "Password": "Security123!Demo"
      },
      {
        "Account": "scanner",
        "UserName": "弱掃分析員",
        "Email": "scanner@local",
        "RoleName": "Scanner",
        "Password": "Scanner123!Demo"
      },
      {
        "Account": "viewer",
        "UserName": "稽核檢視者",
        "Email": "viewer@local",
        "RoleName": "Viewer",
        "Password": "Viewer123!Demo"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
