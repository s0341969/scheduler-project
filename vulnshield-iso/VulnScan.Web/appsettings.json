{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=VulnScanDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "VulnScan": {
    "ResultRootPath": "C:\\VulnScan\\Results",
    "NmapPath": "nmap",
    "NucleiPath": "nuclei",
    "NmapDownloadPageUrl": "https://nmap.org/download.html",
    "NmapInstallerBaseUrl": "https://nmap.org/dist/",
    "InstallerCachePath": "App_Data\\Installers",
    "MaxConcurrentScans": 2,
    "AllowExternalTargets": false,
    "EnablePatchVersionCheck": true
  },
  "LocalAuth": {
    "BootstrapUsers": [
      {
        "Account": "admin",
        "UserName": "系統管理員",
        "Email": "admin@local",
        "RoleName": "Admin",
        "Password": "ChangeThisAdminPassword!"
      },
      {
        "Account": "secmgr",
        "UserName": "資安主管",
        "Email": "security@local",
        "RoleName": "SecurityManager",
        "Password": "ChangeThisSecurityPassword!"
      },
      {
        "Account": "scanner",
        "UserName": "弱掃分析員",
        "Email": "scanner@local",
        "RoleName": "Scanner",
        "Password": "ChangeThisScannerPassword!"
      },
      {
        "Account": "viewer",
        "UserName": "稽核檢視者",
        "Email": "viewer@local",
        "RoleName": "Viewer",
        "Password": "ChangeThisViewerPassword!"
      }
    ]
  },
  "Greenbone": {
    "Enabled": false,
    "Host": "greenbone.local",
    "Port": 9390,
    "Username": "",
    "Password": "",
    "IgnoreCertificateErrors": false,
    "SyncTopReports": 10,
    "ReportFilter": "rows=10 sort-reverse=date",
    "ResultFilter": "rows=-1 min_qod=0 apply_overrides=1 levels=hmlg"
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  },
  "RateLimiting": {
    "Api": {
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "QueueLimit": 10
    }
  }
}
