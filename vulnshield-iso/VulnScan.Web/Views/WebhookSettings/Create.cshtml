@model WebhookSetting
@{
    ViewData["Title"] = "新增 Webhook";
}

<div class="panel-card">
    <div class="panel-card-header">
        <h3>新增 Webhook</h3>
    </div>
    <form asp-action="Create" method="post" class="mt-3">
        <div class="mb-3">
            <label asp-for="Url" class="form-label">Webhook URL</label>
            <input asp-for="Url" class="form-control" placeholder="https://example.com/webhook" />
            <span asp-validation-for="Url" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Secret" class="form-label">Secret（選擇性，用於 HMAC 簽章）</label>
            <input asp-for="Secret" class="form-control" placeholder="留空表示不簽章" />
        </div>
        <div class="mb-3">
            <label asp-for="Events" class="form-label">觸發事件</label>
            <select asp-for="Events" class="form-select">
                <option value="ScanCompleted">ScanCompleted - 掃描完成</option>
            </select>
        </div>
        <div class="mb-3 form-check">
            <input asp-for="IsActive" class="form-check-input" checked />
            <label asp-for="IsActive" class="form-check-label">啟用</label>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">儲存</button>
            <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
        </div>
    </form>
</div>
