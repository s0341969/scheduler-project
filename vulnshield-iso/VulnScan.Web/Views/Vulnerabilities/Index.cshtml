@model IReadOnlyList<VulnScan.Web.Models.Vulnerability>
@{
    ViewData["Title"] = "弱點清單";
}

<article class="panel-card">
    <div class="panel-card-header">
        <h3>弱點總表</h3>
        <span class="counter-pill">@Model.Count 筆</span>
    </div>
    <div class="table-responsive">
        <table class="table table-dark-table align-middle">
            <thead>
                <tr>
                    <th>資產</th>
                    <th>IP</th>
                    <th>弱點名稱</th>
                    <th>Severity</th>
                    <th>CVSS</th>
                    <th>狀態</th>
                    <th>負責人</th>
                    <th>到期日</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.Asset?.AssetName ?? "-")</td>
                    <td>@item.IPAddress</td>
                    <td>@item.VulnName</td>
                    <td>@(item.Severity ?? "-")</td>
                    <td>@(item.CVSS?.ToString("0.0") ?? "-")</td>
                    <td><span class="status-pill">@item.Status</span></td>
                    <td>@(item.OwnerUser ?? "-")</td>
                    <td>@(item.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</article>
