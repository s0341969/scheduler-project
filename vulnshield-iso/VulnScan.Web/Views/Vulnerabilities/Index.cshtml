@model VulnScan.Web.ViewModels.VulnerabilitiesIndexViewModel
@{
    ViewData["Title"] = "弱點清單";
}

<section class="panel-card guidance-card">
    <div class="panel-card-header">
        <h3>這頁看什麼</h3>
    </div>
    <div class="guidance-grid">
        <article class="guidance-item">
            <strong>用途</strong>
            <p>這裡看真正的弱點結果，是管理風險、派工修補與追蹤狀態的主要頁面。</p>
        </article>
        <article class="guidance-item">
            <strong>你會看到</strong>
            <p>弱點名稱、資產、IP、`Severity`、`CVSS`、軟體版本、特徵碼版本、狀態與負責人。</p>
        </article>
        <article class="guidance-item">
            <strong>下一步去哪裡</strong>
            <p>要看某次掃描有沒有成功，回 `掃描結果 / 紀錄`。要匯出主管或稽核看的成果，去 `報告 / 匯出`。</p>
        </article>
    </div>
</section>

<section class="split-grid">
    <article class="panel-card">
        <div class="panel-card-header">
            <h3>Nuclei / Nessus 匯入</h3>
        </div>
        <div class="import-grid">
            <form asp-action="ImportNuclei" method="post" enctype="multipart/form-data" class="form-stack import-card">
                @Html.AntiForgeryToken()
                <div>
                    <div class="eyebrow">Nuclei JSON</div>
                    <h4 class="subheading">匯入 Nuclei JSON / JSONL</h4>
                    <p class="text-secondary">支援 `template-id`、`info.name`、`info.severity`、`matched-at`、`host` 與 remediation 欄位。</p>
                </div>
                <input type="file" name="importFile" class="form-control" accept=".json,.jsonl" />
                <button type="submit" class="btn btn-primary">匯入 Nuclei</button>
            </form>

            <form asp-action="ImportNessus" method="post" enctype="multipart/form-data" class="form-stack import-card">
                @Html.AntiForgeryToken()
                <div>
                    <div class="eyebrow">Nessus CSV/XML</div>
                    <h4 class="subheading">匯入 Nessus 結果</h4>
                    <p class="text-secondary">支援 CSV 與 XML，會依 Plugin ID / Name / Host / Port 對應到系統弱點資料。</p>
                </div>
                <input type="file" name="importFile" class="form-control" accept=".csv,.xml" />
                <button type="submit" class="btn btn-primary">匯入 Nessus</button>
            </form>
        </div>
    </article>

    <article class="panel-card">
        <div class="panel-card-header">
            <h3>弱點總表</h3>
            <span class="counter-pill">@Model.TotalCount 筆</span>
        </div>
        <form method="get" class="search-bar filter-bar">
            <input type="text" name="search" value="@Model.SearchTerm" placeholder="搜尋弱點名稱、IP、CVE..." class="form-control" />
            <select name="severity" class="form-select">
                <option value="">全部 Severity</option>
                <option value="Critical" selected="@(Model.SeverityFilter == "Critical")">Critical</option>
                <option value="High" selected="@(Model.SeverityFilter == "High")">High</option>
                <option value="Medium" selected="@(Model.SeverityFilter == "Medium")">Medium</option>
                <option value="Low" selected="@(Model.SeverityFilter == "Low")">Low</option>
                <option value="Info" selected="@(Model.SeverityFilter == "Info")">Info</option>
            </select>
            <select name="status" class="form-select">
                <option value="">全部狀態</option>
                @foreach (var s in VulnScan.Web.Models.VulnerabilityStatus.All)
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
            <button type="submit" class="btn btn-outline-secondary">篩選</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || !string.IsNullOrWhiteSpace(Model.SeverityFilter) || !string.IsNullOrWhiteSpace(Model.StatusFilter))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">清除</a>
            }
        </form>
        <div class="table-responsive">
            <table class="table table-dark-table align-middle">
                <thead>
                    <tr>
                        <th>資產</th>
                        <th>IP</th>
                        <th>弱點名稱</th>
                        <th>軟體版本</th>
                        <th>特徵碼版本</th>
                        <th>Severity</th>
                        <th>CVSS</th>
                        <th>狀態</th>
                        <th>負責人</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@(item.Asset?.AssetName ?? "-")</td>
                        <td>@item.IPAddress</td>
                        <td>@item.VulnName</td>
                        <td>@(item.DetectedVersion ?? item.ServiceName ?? "-")</td>
                        <td>@(item.SignatureVersion ?? "-")</td>
                        <td>@(item.Severity ?? "-")</td>
                        <td>@(item.CVSS?.ToString("0.0") ?? "-")</td>
                        <td><span class="status-pill">@item.Status</span></td>
                        <td>@(item.OwnerUser ?? "-")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.VulnId" class="btn btn-sm btn-outline-secondary">詳情 / 改善</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <nav class="pagination-nav">
            @if (Model.Page > 1)
            {
                <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-severity="@Model.SeverityFilter" asp-route-status="@Model.StatusFilter" asp-route-page="@(Model.Page - 1)" class="btn btn-sm btn-outline-secondary">上一頁</a>
            }
            <span class="pagination-info">第 @Model.Page / @Model.TotalPages 頁（共 @Model.TotalCount 筆）</span>
            @if (Model.Page < Model.TotalPages)
            {
                <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-severity="@Model.SeverityFilter" asp-route-status="@Model.StatusFilter" asp-route-page="@(Model.Page + 1)" class="btn btn-sm btn-outline-secondary">下一頁</a>
            }
        </nav>
    </article>
</section>
