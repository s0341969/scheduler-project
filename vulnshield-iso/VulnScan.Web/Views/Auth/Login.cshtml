@{
    Layout = null;
    ViewData["Title"] = "登入";
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>登入 - VulnScan Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-body">
    <main class="login-shell">
        <section class="login-card">
            <div class="eyebrow">VulnScan Web</div>
            <h1>企業弱點掃描管理平台</h1>
            <p class="text-secondary">以資料庫中的帳號與個別密碼進行登入。初始帳號密碼由 `appsettings` 的 bootstrap users 產生，登入後可再變更。</p>

            <form asp-action="Login" method="post" class="form-stack">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div>
                    <label class="form-label" for="account">帳號</label>
                    <input id="account" name="account" class="form-control form-control-lg" autocomplete="username" />
                </div>
                <div>
                    <label class="form-label" for="password">密碼</label>
                    <input id="password" name="password" type="password" class="form-control form-control-lg" autocomplete="current-password" />
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100">登入系統</button>
            </form>
        </section>
    </main>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
