@model VulnScan.Web.ViewModels.AssetsIndexViewModel
@{
    ViewData["Title"] = "資產清冊";
}

<section class="split-grid">
    <article class="panel-card">
        <div class="panel-card-header">
            <h3>新增資產</h3>
        </div>
        <form asp-action="Create" method="post" class="form-grid">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div>
                <label asp-for="Form.AssetName" class="form-label"></label>
                <input asp-for="Form.AssetName" class="form-control" />
                <span asp-validation-for="Form.AssetName" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Form.IPAddress" class="form-label"></label>
                <input asp-for="Form.IPAddress" class="form-control" />
                <span asp-validation-for="Form.IPAddress" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Form.HostName" class="form-label"></label>
                <input asp-for="Form.HostName" class="form-control" />
            </div>
            <div>
                <label asp-for="Form.AssetType" class="form-label"></label>
                <select asp-for="Form.AssetType" class="form-select">
                    <option value="">請選擇</option>
                    <option>Server</option>
                    <option>Firewall</option>
                    <option>Switch</option>
                    <option>Router</option>
                    <option>NAS</option>
                    <option>Workstation</option>
                    <option>Printer</option>
                    <option>IoT</option>
                </select>
            </div>
            <div>
                <label asp-for="Form.OwnerDept" class="form-label"></label>
                <input asp-for="Form.OwnerDept" class="form-control" />
            </div>
            <div>
                <label asp-for="Form.OwnerUser" class="form-label"></label>
                <input asp-for="Form.OwnerUser" class="form-control" />
            </div>
            <div>
                <label asp-for="Form.Importance" class="form-label"></label>
                <select asp-for="Form.Importance" class="form-select">
                    <option value="">請選擇</option>
                    <option>Critical</option>
                    <option>High</option>
                    <option>Medium</option>
                    <option>Low</option>
                </select>
            </div>
            <div class="form-check align-self-end">
                <input asp-for="Form.IsActive" class="form-check-input" />
                <label asp-for="Form.IsActive" class="form-check-label">啟用資產</label>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">建立資產</button>
            </div>
        </form>
    </article>

    <article class="panel-card">
        <div class="panel-card-header">
            <h3>資產列表</h3>
            <span class="counter-pill">@Model.Items.Count 筆</span>
        </div>
        <div class="table-responsive">
            <table class="table table-dark-table align-middle">
                <thead>
                    <tr>
                        <th>名稱</th>
                        <th>IP</th>
                        <th>類型</th>
                        <th>負責單位</th>
                        <th>重要性</th>
                        <th>最後掃描</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.AssetName</td>
                        <td>@item.IPAddress</td>
                        <td>@(item.AssetType ?? "-")</td>
                        <td>@(item.OwnerDept ?? "-")</td>
                        <td>@(item.Importance ?? "-")</td>
                        <td>@(item.LastScanTime?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </article>
</section>
