@model VulnScan.Web.ViewModels.ScanJobViewModel
@{
    ViewData["Title"] = "編輯掃描任務";
}

<article class="panel-card panel-card-narrow">
    <div class="panel-card-header">
        <h3>編輯掃描任務</h3>
    </div>
    <form asp-action="Edit" asp-route-id="@Model.JobId" method="post" class="form-grid">
        @Html.AntiForgeryToken()
        <input asp-for="JobId" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger full-width"></div>
        <div>
            <label asp-for="JobName" class="form-label"></label>
            <input asp-for="JobName" class="form-control" />
            <span asp-validation-for="JobName" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="TargetRange" class="form-label"></label>
            <input asp-for="TargetRange" class="form-control" />
            <span asp-validation-for="TargetRange" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="ScanType" class="form-label"></label>
            <select asp-for="ScanType" class="form-select">
                <option>PortScan</option>
                <option>ServiceDetect</option>
                <option>BaselineScan</option>
                <option>VulnerabilityScan</option>
                <option>WebScan</option>
                <option>AllScan</option>
            </select>
        </div>
        <div>
            <label asp-for="ScanTool" class="form-label"></label>
            <select asp-for="ScanTool" class="form-select" id="editScanTool">
                <option value="Nmap">Nmap</option>
                <option value="Nuclei">Nuclei</option>
            </select>
        </div>
        <div>
            <label asp-for="ScanProfile" class="form-label" id="editProfileLabel">掃描強度</label>
            <select asp-for="ScanProfile" class="form-select" id="editScanProfile">
                <optgroup label="Nmap 模式">
                    <option value="Quick">Quick - 快速連接埠掃描</option>
                    <option value="QuickPlus">QuickPlus - 快速+版本偵測</option>
                    <option value="Standard">Standard - 標準+版本+OS</option>
                    <option value="Deep">Deep - 深度掃描+A+完整版本</option>
                    <option value="Stealth">Stealth - 隱匿模式</option>
                    <option value="VulnScript">VulnScript - 安全腳本掃描</option>
                </optgroup>
                <optgroup label="Nuclei 範本">
                    <option value="All">All - 所有範本</option>
                    <option value="cves">CVEs - 已知 CVE</option>
                    <option value="vulnerabilities">Vulnerabilities - 一般弱點</option>
                    <option value="misconfiguration">Misconfig - 錯誤設定</option>
                    <option value="exposures">Exposures - 曝露</option>
                    <option value="default-logins">DefaultLogins - 預設登入</option>
                </optgroup>
            </select>
        </div>
        <div>
            <label asp-for="ScheduleType" class="form-label"></label>
            <input asp-for="ScheduleType" class="form-control" />
        </div>
        <div>
            <label asp-for="ScheduleTime" class="form-label"></label>
            <input asp-for="ScheduleTime" class="form-control" type="time" />
        </div>
        <div>
            <label asp-for="CronExpression" class="form-label"></label>
            <input asp-for="CronExpression" class="form-control" />
        </div>
        <div class="form-check align-self-end">
            <input asp-for="IsEnabled" class="form-check-input" />
            <label asp-for="IsEnabled" class="form-check-label">啟用任務</label>
        </div>
        <div class="form-actions action-row">
            <button type="submit" class="btn btn-primary">儲存變更</button>
            <a asp-action="Index" class="btn btn-outline-secondary">返回列表</a>
        </div>
    </form>
</article>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var toolSelect = document.getElementById('editScanTool');
            var profileSelect = document.getElementById('editScanProfile');
            var profileLabel = document.getElementById('editProfileLabel');

            function updateProfileOptions() {
                var tool = toolSelect.value;
                for (var i = 0; i < profileSelect.options.length; i++) {
                    var opt = profileSelect.options[i];
                    if (opt.tagName === 'OPTGROUP') {
                        opt.style.display = (tool === 'Nuclei' && opt.label === 'Nuclei 範本') || (tool === 'Nmap' && opt.label === 'Nmap 模式') ? '' : 'none';
                    }
                }
                profileLabel.textContent = tool === 'Nuclei' ? '弱點範本' : '掃描強度';
            }

            toolSelect.addEventListener('change', updateProfileOptions);
            updateProfileOptions();
        });
    </script>
}
