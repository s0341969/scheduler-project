@model VulnScan.Web.ViewModels.ScanJobsIndexViewModel
@{
    ViewData["Title"] = "掃描任務";
}

<div id="scan-running-indicator" class="panel-card running-scans-card" style="display:none">
    <div class="panel-card-header">
        <h3>執行中的掃描</h3>
        <span class="status-pill status-pill-running">執行中</span>
    </div>
    <div class="scan-running-list"></div>
</div>

@if (Model.Nmap is not null && !Model.Nmap.IsInstalled)
{
    <section class="panel-card preflight-alert-card">
        <div class="panel-card-header">
            <h3>Nmap 執行前檢查未通過</h3>
            <span class="status-pill preflight-status-pill">Blocked</span>
        </div>
        <div class="form-stack">
            <p class="mb-0">目前系統找不到 `nmap.exe`，因此使用 `Nmap` 的掃描任務會在建立執行紀錄前直接被阻擋。</p>
            <dl class="detail-grid">
                <dt>目前狀態</dt>
                <dd>@Model.Nmap.StatusText</dd>
                <dt>實際找到的路徑</dt>
                <dd class="path-cell">@Model.Nmap.ResolvedPath</dd>
                <dt>來源</dt>
                <dd>@Model.Nmap.Source</dd>
                <dt>處理方式</dt>
                <dd>@Model.Nmap.Message</dd>
            </dl>
            <div class="action-row">
                <a asp-controller="SystemCheck" asp-action="Index" class="btn btn-outline-secondary">前往系統檢查</a>
                @if (Model.Nmap.CanStartInstall && (User.IsInRole("Admin") || User.IsInRole("SecurityManager")))
                {
                    <form asp-controller="SystemCheck" asp-action="InstallNmap" method="post" class="inline-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@Url.Action("Index", "ScanJobs")" />
                        <button type="submit" class="btn btn-primary">直接安裝 Nmap</button>
                    </form>
                }
            </div>
        </div>
    </section>
}

<section class="split-grid">
    <article class="panel-card">
        <div class="panel-card-header">
            <h3>建立掃描任務</h3>
        </div>
        <form asp-action="Create" method="post" class="form-grid">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div>
                <label asp-for="Form.JobName" class="form-label"></label>
                <input asp-for="Form.JobName" class="form-control" />
                <span asp-validation-for="Form.JobName" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Form.TargetRange" class="form-label"></label>
                <input asp-for="Form.TargetRange" class="form-control" />
                <span asp-validation-for="Form.TargetRange" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Form.ScanType" class="form-label"></label>
                <select asp-for="Form.ScanType" class="form-select">
                    <option>PortScan</option>
                    <option>ServiceDetect</option>
                    <option>BaselineScan</option>
                    <option>VulnerabilityScan</option>
                    <option>WebScan</option>
                </select>
            </div>
            <div>
                <label asp-for="Form.ScanTool" class="form-label"></label>
                <select asp-for="Form.ScanTool" class="form-select" id="scanToolSelect">
                    <option value="Nmap">Nmap</option>
                    <option value="Nuclei">Nuclei</option>
                </select>
            </div>
            <div>
                <label asp-for="Form.ScanProfile" class="form-label" id="scanProfileLabel">掃描強度</label>
                <select asp-for="Form.ScanProfile" class="form-select" id="scanProfileSelect">
                    <optgroup label="Nmap 模式">
                        <option value="Quick">Quick - 快速連接埠掃描</option>
                        <option value="QuickPlus" selected>QuickPlus - 快速+版本偵測</option>
                        <option value="Standard">Standard - 標準+版本+OS</option>
                        <option value="Deep">Deep - 深度掃描+A+完整版本</option>
                        <option value="Stealth">Stealth - 隱匿模式</option>
                        <option value="VulnScript">VulnScript - 安全腳本掃描</option>
                    </optgroup>
                    <optgroup label="Nuclei 範本">
                        <option value="All">All - 所有範本</option>
                        <option value="cves">CVEs - 已知 CVE</option>
                        <option value="vulnerabilities">Vulnerabilities - 一般弱點</option>
                        <option value="misconfiguration">Misconfig - 錯誤設定</option>
                        <option value="exposures">Exposures - 曝露</option>
                        <option value="default-logins">DefaultLogins - 預設登入</option>
                    </optgroup>
                </select>
            </div>
            <div>
                <label asp-for="Form.ScheduleType" class="form-label"></label>
                <select asp-for="Form.ScheduleType" class="form-select">
                    <option value="">不排程</option>
                    <option>Daily</option>
                    <option>Weekly</option>
                    <option>Cron</option>
                </select>
            </div>
            <div>
                <label asp-for="Form.ScheduleTime" class="form-label"></label>
                <input asp-for="Form.ScheduleTime" class="form-control" type="time" />
            </div>
            <div class="full-width">
                <label asp-for="Form.CronExpression" class="form-label"></label>
                <input asp-for="Form.CronExpression" class="form-control" />
            </div>
            <div class="form-check align-self-end">
                <input asp-for="Form.IsEnabled" class="form-check-input" />
                <label asp-for="Form.IsEnabled" class="form-check-label">啟用任務</label>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">建立任務</button>
            </div>
        </form>
    </article>

    <article class="panel-card">
        <div class="panel-card-header">
            <h3>任務列表</h3>
            <span class="counter-pill">@Model.TotalCount 筆</span>
        </div>
        <form method="get" class="search-bar">
            <input type="text" name="search" value="@Model.SearchTerm" placeholder="搜尋任務名稱、目標..." class="form-control" />
            <button type="submit" class="btn btn-outline-secondary">搜尋</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">清除</a>
            }
        </form>
        <div class="table-responsive">
            <table class="table table-dark-table align-middle">
                <thead>
                    <tr>
                        <th>任務名稱</th>
                        <th>目標</th>
                        <th>類型</th>
                        <th>工具</th>
                        <th>強度</th>
                        <th>排程</th>
                        <th>動作</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.JobName</td>
                        <td>@item.TargetRange</td>
                        <td>@item.ScanType</td>
                        <td>@item.ScanTool</td>
                        <td>@(item.ScanProfile ?? "-")</td>
                        <td>@(item.ScheduleType ?? "-")</td>
                        <td>
                            <div class="action-stack">
                                <form asp-action="RunNow" method="post" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.JobId" />
                                    @{
                                        var isDisabled = (item.ScanTool == "Nmap" && Model.Nmap is not null && !Model.Nmap.IsInstalled);
                                    }
                                    @if (isDisabled)
                                    {
                                        <button type="submit" class="btn btn-sm btn-primary" disabled title="Nmap 未安裝或路徑不正確">立即掃描</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-primary">立即掃描</button>
                                    }
                                </form>
                                <a asp-action="Edit" asp-route-id="@item.JobId" class="btn btn-sm btn-outline-secondary">編輯</a>
                                <form asp-action="Delete" asp-route-id="@item.JobId" method="post" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('確定刪除此掃描任務？');">刪除</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <nav class="pagination-nav">
            @if (Model.Page > 1)
            {
                <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-page="@(Model.Page - 1)" class="btn btn-sm btn-outline-secondary">上一頁</a>
            }
            <span class="pagination-info">第 @Model.Page / @Model.TotalPages 頁（共 @Model.TotalCount 筆）</span>
            @if (Model.Page < Model.TotalPages)
            {
                <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-page="@(Model.Page + 1)" class="btn btn-sm btn-outline-secondary">下一頁</a>
            }
        </nav>
    </article>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var toolSelect = document.getElementById('scanToolSelect');
            var profileSelect = document.getElementById('scanProfileSelect');
            var profileLabel = document.getElementById('scanProfileLabel');

            function updateProfileOptions() {
                var tool = toolSelect.value;
                for (var i = 0; i < profileSelect.options.length; i++) {
                    var opt = profileSelect.options[i];
                    if (opt.tagName === 'OPTGROUP') {
                        opt.style.display = (tool === 'Nuclei' && opt.label === 'Nuclei 範本') || (tool === 'Nmap' && opt.label === 'Nmap 模式') ? '' : 'none';
                    }
                }
                // Auto-select first visible option if current is hidden
                var visibleGroup = null;
                for (var i = 0; i < profileSelect.options.length; i++) {
                    var opt = profileSelect.options[i];
                    if (opt.tagName === 'OPTGROUP') {
                        visibleGroup = opt.style.display !== 'none' ? opt : null;
                    } else if (opt.tagName !== 'OPTGROUP' && visibleGroup && opt.style.display !== 'none') {
                        profileSelect.value = opt.value;
                        break;
                    }
                }
                profileLabel.textContent = tool === 'Nuclei' ? '弱點範本' : '掃描強度';
            }

            toolSelect.addEventListener('change', updateProfileOptions);
            updateProfileOptions();
        });
    </script>
}
