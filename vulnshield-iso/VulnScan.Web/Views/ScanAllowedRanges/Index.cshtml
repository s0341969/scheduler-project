@model VulnScan.Web.ViewModels.ScanAllowedRangesIndexViewModel
@{
    ViewData["Title"] = "掃描白名單";
}

<section class="split-grid">
    <article class="panel-card">
        <div class="panel-card-header">
            <h3>新增白名單範圍</h3>
        </div>
        <form asp-action="Create" method="post" class="form-grid">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div>
                <label asp-for="Form.RangeName" class="form-label"></label>
                <input asp-for="Form.RangeName" class="form-control" />
                <span asp-validation-for="Form.RangeName" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Form.Cidr" class="form-label"></label>
                <input asp-for="Form.Cidr" class="form-control" />
                <span asp-validation-for="Form.Cidr" class="text-danger"></span>
            </div>
            <div class="full-width">
                <label asp-for="Form.Description" class="form-label"></label>
                <textarea asp-for="Form.Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="form-check align-self-end">
                <input asp-for="Form.IsEnabled" class="form-check-input" />
                <label asp-for="Form.IsEnabled" class="form-check-label">啟用範圍</label>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">新增白名單</button>
            </div>
        </form>
    </article>

    <article class="panel-card">
        <div class="panel-card-header">
            <h3>白名單列表</h3>
            <span class="counter-pill">@Model.TotalCount 筆</span>
        </div>
        <form method="get" class="search-bar">
            <input type="text" name="search" value="@Model.SearchTerm" placeholder="搜尋名稱、CIDR..." class="form-control" />
            <button type="submit" class="btn btn-outline-secondary">搜尋</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">清除</a>
            }
        </form>
        <div class="table-responsive">
            <table class="table table-dark-table align-middle">
                <thead>
                    <tr>
                        <th>名稱</th>
                        <th>CIDR / Range</th>
                        <th>狀態</th>
                        <th>說明</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.RangeName</td>
                        <td>@item.Cidr</td>
                        <td><span class="status-pill">@(item.IsEnabled ? "Enabled" : "Disabled")</span></td>
                        <td>@(item.Description ?? "-")</td>
                        <td class="action-cell">
                            <a asp-action="Edit" asp-route-id="@item.RangeId" class="btn btn-sm btn-outline-secondary">編輯</a>
                            <form asp-action="Delete" asp-route-id="@item.RangeId" method="post" class="inline-form">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('確定刪除此白名單範圍？');">刪除</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <nav class="pagination-nav">
            @if (Model.Page > 1)
            {
                <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-page="@(Model.Page - 1)" class="btn btn-sm btn-outline-secondary">上一頁</a>
            }
            <span class="pagination-info">第 @Model.Page / @Model.TotalPages 頁（共 @Model.TotalCount 筆）</span>
            @if (Model.Page < Model.TotalPages)
            {
                <a asp-action="Index" asp-route-search="@Model.SearchTerm" asp-route-page="@(Model.Page + 1)" class="btn btn-sm btn-outline-secondary">下一頁</a>
            }
        </nav>
    </article>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
