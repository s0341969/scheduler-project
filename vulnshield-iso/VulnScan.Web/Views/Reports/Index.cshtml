@model VulnScan.Web.ViewModels.ReportsIndexViewModel
@{
    ViewData["Title"] = "報表匯出";
}

<section class="panel-card guidance-card">
    <div class="panel-card-header">
        <h3>這頁看什麼</h3>
    </div>
    <div class="guidance-grid">
        <article class="guidance-item">
            <strong>用途</strong>
            <p>這裡用來看整體弱點摘要，並輸出 `Excel / PDF` 報告給主管、稽核或客戶。</p>
        </article>
        <article class="guidance-item">
            <strong>你會看到</strong>
            <p>弱點總數、高風險弱點、最近檢測結果，以及最近匯出的報告紀錄。</p>
        </article>
        <article class="guidance-item">
            <strong>下一步去哪裡</strong>
            <p>想看每次掃描有沒有成功，去 `掃描結果 / 紀錄`。想看每一筆實際弱點明細，去 `弱點結果`。</p>
        </article>
    </div>
</section>

<section class="hero-grid">
    <article class="metric-card">
        <span class="metric-label">弱點總數</span>
        <strong class="metric-value">@Model.VulnerabilityCount</strong>
    </article>
    <article class="metric-card">
        <span class="metric-label">高風險弱點</span>
        <strong class="metric-value">@Model.HighRiskCount</strong>
    </article>
    <article class="metric-card">
        <span class="metric-label">歷史匯出</span>
        <strong class="metric-value">@Model.ExportCount</strong>
    </article>
</section>

<section class="panel-card">
    <div class="panel-card-header">
        <h3>最近檢測弱點、軟體版本與特徵碼版本</h3>
    </div>
    <div class="table-responsive">
        <table class="table table-dark-table align-middle">
            <thead>
                <tr>
                    <th>資產</th>
                    <th>IP</th>
                    <th>弱點名稱</th>
                    <th>軟體版本</th>
                    <th>特徵碼版本</th>
                    <th>Severity</th>
                    <th>最後發現時間</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.RecentFindings)
            {
                <tr>
                    <td>@(item.Asset?.AssetName ?? "-")</td>
                    <td>@(item.IPAddress ?? "-")</td>
                    <td>@item.VulnName</td>
                    <td>@(item.DetectedVersion ?? item.ServiceName ?? "-")</td>
                    <td>@(item.SignatureVersion ?? "-")</td>
                    <td>@(item.Severity ?? "-")</td>
                    <td>@item.LastDetectedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

<section class="split-grid">
    <article class="panel-card">
        <div class="panel-card-header">
            <h3>立即匯出</h3>
        </div>
        <div class="form-stack">
            <form asp-action="ExportHighRisk" method="post" class="form-stack">
                @Html.AntiForgeryToken()
                <p>可立即匯出高風險弱點 Excel，內容會包含 `軟體版本` 與 `特徵碼版本`。</p>
                <button type="submit" class="btn btn-primary">匯出高風險弱點 Excel</button>
            </form>
            <form asp-action="ExportPdf" method="post" class="form-grid">
                @Html.AntiForgeryToken()
                <div>
                    <label asp-for="StartDate" class="form-label">開始日期</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                </div>
                <div>
                    <label asp-for="EndDate" class="form-label">結束日期</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                </div>
                <div class="full-width">
                    <p>PDF 會輸出摘要 KPI 與弱點明細，並包含 `軟體版本 / 特徵碼版本`。</p>
                </div>
                <div class="action-row full-width">
                    <button type="submit" class="btn btn-outline-secondary">匯出 PDF 報表</button>
                </div>
            </form>
        </div>
    </article>

    <article class="panel-card">
        <div class="panel-card-header">
            <h3>最近匯出紀錄</h3>
        </div>
        <div class="table-responsive">
            <table class="table table-dark-table align-middle">
                <thead>
                    <tr>
                        <th>報表名稱</th>
                        <th>類型</th>
                        <th>路徑</th>
                        <th>時間</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.RecentExports)
                {
                    <tr>
                        <td>@item.ReportName</td>
                        <td>@item.ReportType</td>
                        <td class="path-cell">@item.FilePath</td>
                        <td>@item.ExportedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </article>
</section>
