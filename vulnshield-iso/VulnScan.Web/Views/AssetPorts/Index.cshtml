@model IReadOnlyList<VulnScan.Web.Models.AssetPort>
@{
    ViewData["Title"] = "Port / Service 結果";
}

<section class="panel-card guidance-card">
    <div class="panel-card-header">
        <h3>這頁看什麼</h3>
    </div>
    <div class="guidance-grid">
        <article class="guidance-item">
            <strong>用途</strong>
            <p>這裡看掃描後實際發現的開放 `Port / Service`，用來確認目標主機到底對外暴露了哪些服務。</p>
        </article>
        <article class="guidance-item">
            <strong>你會看到</strong>
            <p>`IP`、`Port`、`Protocol`、`Service`、`Product`、`Version`，以及系統判斷的 `Risk Hint`。</p>
        </article>
        <article class="guidance-item">
            <strong>下一步去哪裡</strong>
            <p>若只想知道掃描是否成功，回 `掃描結果 / 紀錄`。若要看這些服務對應出了哪些弱點，去 `弱點結果`。</p>
        </article>
    </div>
</section>

<article class="panel-card">
    <div class="panel-card-header">
        <h3>Port 與服務結果</h3>
        <span class="counter-pill">@Model.Count 筆</span>
    </div>
    <div class="table-responsive">
        <table class="table table-dark-table align-middle">
            <thead>
                <tr>
                    <th>資產</th>
                    <th>IP</th>
                    <th>Port</th>
                    <th>Protocol</th>
                    <th>Service</th>
                    <th>Product</th>
                    <th>Version</th>
                    <th>Risk Hint</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(item.Asset?.AssetName ?? "-")</td>
                    <td>@item.IPAddress</td>
                    <td>@item.PortNumber</td>
                    <td>@item.Protocol</td>
                    <td>@item.ServiceName</td>
                    <td>@item.ServiceProduct</td>
                    <td>@item.ServiceVersion</td>
                    <td>@(item.RiskHint ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</article>
