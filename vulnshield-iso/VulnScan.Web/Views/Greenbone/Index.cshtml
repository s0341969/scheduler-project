@model VulnScan.Web.ViewModels.GreenboneIndexViewModel
@{
    ViewData["Title"] = "Greenbone 整合";
}

<section class="hero-grid">
    <article class="metric-card">
        <span class="metric-label">設定狀態</span>
        <strong class="metric-value">@(Model.Settings.IsEnabled ? "啟用中" : "停用")</strong>
    </article>
    <article class="metric-card">
        <span class="metric-label">最近成功同步</span>
        <strong class="metric-value">@Model.SuccessCount</strong>
    </article>
    <article class="metric-card">
        <span class="metric-label">最近失敗同步</span>
        <strong class="metric-value">@Model.FailureCount</strong>
    </article>
</section>

<section class="split-grid">
    <article class="panel-card">
        <div class="panel-card-header">
            <h3>連線與同步設定</h3>
        </div>
        <form asp-action="Save" method="post" class="form-grid">
            @Html.AntiForgeryToken()
            <input asp-for="Settings.HasStoredPassword" type="hidden" />
            <div class="form-check full-width">
                <input asp-for="Settings.IsEnabled" class="form-check-input" />
                <label asp-for="Settings.IsEnabled" class="form-check-label">啟用 Greenbone / OpenVAS API 同步</label>
            </div>
            <div>
                <label asp-for="Settings.Host" class="form-label"></label>
                <input asp-for="Settings.Host" class="form-control" />
                <span asp-validation-for="Settings.Host" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Settings.Port" class="form-label"></label>
                <input asp-for="Settings.Port" class="form-control" />
                <span asp-validation-for="Settings.Port" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Settings.Username" class="form-label"></label>
                <input asp-for="Settings.Username" class="form-control" />
                <span asp-validation-for="Settings.Username" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Settings.Password" class="form-label">密碼</label>
                <input asp-for="Settings.Password" class="form-control" />
                <small class="text-secondary">@(Model.Settings.HasStoredPassword ? "留白表示沿用目前已保存密碼。" : "首次設定請輸入密碼。")</small>
            </div>
            <div class="form-check full-width">
                <input asp-for="Settings.IgnoreCertificateErrors" class="form-check-input" />
                <label asp-for="Settings.IgnoreCertificateErrors" class="form-check-label">忽略 TLS 憑證錯誤（僅限內部測試環境）</label>
            </div>
            <div>
                <label asp-for="Settings.SyncTopReports" class="form-label"></label>
                <input asp-for="Settings.SyncTopReports" class="form-control" />
                <span asp-validation-for="Settings.SyncTopReports" class="text-danger"></span>
            </div>
            <div class="full-width">
                <label asp-for="Settings.ReportFilter" class="form-label"></label>
                <input asp-for="Settings.ReportFilter" class="form-control" />
                <span asp-validation-for="Settings.ReportFilter" class="text-danger"></span>
            </div>
            <div class="full-width">
                <label asp-for="Settings.ResultFilter" class="form-label"></label>
                <input asp-for="Settings.ResultFilter" class="form-control" />
                <span asp-validation-for="Settings.ResultFilter" class="text-danger"></span>
            </div>
            <div class="action-row full-width">
                <button type="submit" class="btn btn-primary">儲存設定</button>
            </div>
        </form>
    </article>

    <article class="panel-card">
        <div class="panel-card-header">
            <h3>立即同步</h3>
        </div>
        <div class="form-stack">
            <p>這裡會直接使用目前已儲存的 Greenbone 設定發動一次 API 同步，並把每一份報表的成功或失敗原因寫入下方紀錄。</p>
            <form asp-action="SyncNow" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary">立即同步一次</button>
            </form>
        </div>
    </article>
</section>

<section class="panel-card">
    <div class="panel-card-header">
        <h3>最近同步明細</h3>
    </div>
    <div class="table-responsive">
        <table class="table table-dark-table align-middle">
            <thead>
                <tr>
                    <th>時間</th>
                    <th>模式</th>
                    <th>狀態</th>
                    <th>端點</th>
                    <th>報表</th>
                    <th>任務</th>
                    <th>匯入筆數</th>
                    <th>訊息</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.RecentLogs)
            {
                <tr>
                    <td>@item.StartedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@item.TriggerMode</td>
                    <td>@item.Status</td>
                    <td>@item.Endpoint</td>
                    <td class="path-cell">@(item.ReportId ?? "-")</td>
                    <td>@(item.TaskName ?? "-")</td>
                    <td>@item.ImportedCount</td>
                    <td class="path-cell">@(item.Message ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
