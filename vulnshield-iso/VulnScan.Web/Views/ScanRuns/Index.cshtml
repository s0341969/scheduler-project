@model IReadOnlyList<VulnScan.Web.Models.ScanRun>
@{
    ViewData["Title"] = "掃描紀錄";
}

<section class="panel-card guidance-card">
    <div class="panel-card-header">
        <h3>這頁看什麼</h3>
    </div>
    <div class="guidance-grid">
        <article class="guidance-item">
            <strong>用途</strong>
            <p>這裡看每一次掃描有沒有成功執行，適合先確認 `Completed / Failed`、執行時間與錯誤原因。</p>
        </article>
        <article class="guidance-item">
            <strong>你會看到</strong>
            <p>`Host`、`Open Port`、`弱點數`、開始 / 結束時間，以及失敗時的錯誤訊息。</p>
        </article>
        <article class="guidance-item">
            <strong>下一步去哪裡</strong>
            <p>想看開了哪些服務，去 `服務結果`。想看實際弱點，去 `弱點結果`。想輸出主管報告，去 `報告 / 匯出`。</p>
        </article>
    </div>
</section>

<article class="panel-card">
    <div class="panel-card-header">
        <h3>掃描執行紀錄</h3>
        <span class="counter-pill">@Model.Count 筆</span>
    </div>
    <div class="table-responsive">
        <table class="table table-dark-table align-middle">
            <thead>
                <tr>
                    <th>RunID</th>
                    <th>任務</th>
                    <th>狀態</th>
                    <th>Host</th>
                    <th>Open Port</th>
                    <th>弱點數</th>
                    <th>開始</th>
                    <th>結束</th>
                    <th>錯誤</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.RunId</td>
                    <td>@(item.ScanJob?.JobName ?? item.JobId.ToString())</td>
                    <td><span class="status-pill">@item.Status</span></td>
                    <td>@item.TotalHosts</td>
                    <td>@item.TotalOpenPorts</td>
                    <td>@item.TotalVulnerabilities</td>
                    <td>@item.StartTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@(item.EndTime?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                    <td>@(item.ErrorMessage ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</article>
