<Window x:Class="SchedulerDragDrop.ShiftToDateTimeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="推移到指定日期時段"
        Height="220"
        Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="將選取製程推移到：" FontWeight="SemiBold" Margin="0,0,0,12" />

        <DatePicker x:Name="TargetDatePicker" Grid.Row="1" Margin="0,0,0,12" />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <ComboBox x:Name="HourComboBox" Width="80" Margin="0,0,8,0" />
            <ComboBox x:Name="MinuteComboBox" Width="80" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="88" Margin="0,0,8,0" IsDefault="True" Click="Ok_Click">確定</Button>
            <Button Width="88" IsCancel="True">取消</Button>
        </StackPanel>
    </Grid>
</Window>

