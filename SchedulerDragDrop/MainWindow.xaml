<Window x:Class="SchedulerDragDrop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="生產排程系統（拖拉排程）" Height="780" Width="1520" WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <WrapPanel ItemHeight="40" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="PRDOPGP 群組" Margin="0,0,8,0" />
                    <Button Width="170" Height="36" Margin="0,0,8,0" Click="OpenProcessGroupDialog_Click">選擇群組...</Button>
                    <TextBlock Width="220" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555" Text="{Binding ProcessGroupSummary}" TextTrimming="CharacterEllipsis" />

                    <Button Width="140" Height="36" Margin="0,0,8,0" Click="QuerySchedule_Click">查詢排程</Button>
                    <ProgressBar Width="180" Height="16" Margin="0,10,8,0" VerticalAlignment="Top" Maximum="{Binding ProgressMaximum, Mode=OneWay}" Value="{Binding ProgressValue, Mode=OneWay}" IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}" />
                    <TextBlock Width="56" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#1F2937" FontWeight="SemiBold" Text="{Binding ProgressPercentText}" />
                    <TextBlock Width="300" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#374151" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
                    <Button Width="120" Height="36" Margin="0,0,8,0" Click="CancelQuery_Click" IsEnabled="{Binding IsBusy}">中止查詢</Button>

                    <Button Width="160" Height="36" Margin="0,0,8,0" Click="AutoSchedule_Click">自動排程</Button>
                    <Button Width="160" Height="36" Margin="0,0,8,0" Click="Recalculate_Click">重新計算</Button>
                    <Button Width="160" Height="36" Margin="0,0,8,0" Click="ShiftSelectedEarlier_Click">選取項目 -1 小時</Button>
                    <Button Width="160" Height="36" Margin="0,0,8,0" Click="ShiftSelectedLater_Click">選取項目 +1 小時</Button>
                </WrapPanel>
            </ScrollViewer>

            <WrapPanel Margin="0,6,0,0" ItemHeight="36" Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="機台寬度" Margin="0,0,8,0" />
                <Slider Width="180" Minimum="120" Maximum="360" Value="{Binding LaneWidth, Mode=OneWay}" TickFrequency="10" IsSnapToTickEnabled="False" ValueChanged="LaneWidthSlider_ValueChanged" />
                <TextBlock VerticalAlignment="Center" Margin="8,0,20,0" Text="{Binding LaneWidth, StringFormat={}{0:0}px}" />

                <TextBlock VerticalAlignment="Center" Text="時間軸高度" Margin="0,0,8,0" />
                <Slider x:Name="ZoomSlider" Width="180" Minimum="20" Maximum="96" Value="24" TickFrequency="4" IsSnapToTickEnabled="False" ValueChanged="ZoomSlider_ValueChanged" />
                <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Text="{Binding TimeAxisHeightLabel}" />
            </WrapPanel>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" BorderBrush="#D0D0D0" BorderThickness="1" Background="#F8FAFC" Padding="8">
                <TextBlock Text="時間軸" FontWeight="Bold" FontSize="14" />
            </Border>

            <ScrollViewer x:Name="HeaderScrollViewer" Grid.Row="0" Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="HeaderItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="{Binding DataContext.LaneWidth, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,10,0" Padding="8" BorderBrush="#D0D0D0" BorderThickness="1" Background="#F8FAFC">
                                <TextBlock Text="{Binding Header}" FontWeight="Bold" FontSize="14" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="0" Grid.Column="2" BorderBrush="#D0D0D0" BorderThickness="1" Background="#F8FAFC" Padding="8">
                <TextBlock Text="選取製卡製程" FontWeight="Bold" FontSize="14" />
            </Border>

            <Border Grid.Row="1" Grid.Column="0" BorderBrush="#D0D0D0" BorderThickness="1" Background="#FFFFFF">
                <ScrollViewer x:Name="TimeAxisScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" ScrollChanged="TimeAxisScrollViewer_ScrollChanged">
                    <ItemsControl x:Name="TimeAxisItemsControl" ItemsSource="{Binding TimeTicks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Height="{Binding DataContext.PixelsPerHour, RelativeSource={RelativeSource AncestorType=Window}}" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="8,12,8,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FFFFFF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWorking}" Value="False">
                                                    <Setter Property="Background" Value="#F3F4F6" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsHoliday}" Value="True">
                                                    <Setter Property="Background" Value="#FECACA" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Label}" FontSize="25" Foreground="#374151" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <ScrollViewer x:Name="LanesScrollViewer"
                          Grid.Row="1"
                          Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          ScrollChanged="LanesScrollViewer_ScrollChanged">
                <ItemsControl x:Name="LaneItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="{Binding DataContext.LaneWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Height="{Binding DataContext.LaneCanvasHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Margin="0,0,10,0"
                                    BorderBrush="#D0D0D0"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Background="#FAFAFA"
                                    AllowDrop="True"
                                    PreviewMouseLeftButtonDown="LaneBackground_PreviewMouseLeftButtonDown"
                                    DragOver="LaneCanvas_DragOver"
                                    Drop="LaneCanvas_Drop">
                                <Grid>
                                    <ItemsControl ItemsSource="{Binding DataContext.TimeTicks, RelativeSource={RelativeSource AncestorType=Window}}" IsHitTestVisible="False">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Height="{Binding DataContext.PixelsPerHour, RelativeSource={RelativeSource AncestorType=Window}}" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#FFFFFF" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsWorking}" Value="False">
                                                    <Setter Property="Background" Value="#F3F4F6" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsHoliday}" Value="True">
                                                    <Setter Property="Background" Value="#FECACA" />
                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <ItemsControl ItemsSource="{Binding Tasks}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas Height="{Binding DataContext.LaneCanvasHeight, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Top" Value="{Binding TopPx}" />
                                                <Setter Property="Canvas.Left" Value="4" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="{Binding DataContext.TaskCardWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Height="{Binding HeightPx}"
                                                        MinHeight="28"
                                                        BorderThickness="2"
                                                        Padding="1"
                                                        CornerRadius="8"
                                                        MouseLeftButtonDown="TaskCard_MouseLeftButtonDown"
                                                        MouseMove="TaskCard_MouseMove">
                                                    <Border.ToolTip>
                                                        <ToolTip>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding Meta}" TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding Meta2}" TextWrapping="Wrap" />
                                                                <TextBlock Text="{Binding StartText}" />
                                                                <TextBlock Text="{Binding EndText}" />
                                                            </StackPanel>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="推移選取項目">
                                                                <MenuItem Header="開啟推移設定..." Click="ShiftSelectedToDateTimeMenu_Click" />
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="Transparent" />
                                                            <Setter Property="Opacity" Value="1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPrimarySelected}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#DC2626" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                                    <Setter Property="Opacity" Value="0.45" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Border BorderThickness="1" CornerRadius="6" Padding="6">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="#EEF2FF" />
                                                                <Setter Property="BorderBrush" Value="#A5B4FC" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRelatedSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#FEF3C7" />
                                                                        <Setter Property="BorderBrush" Value="#F59E0B" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsOperationSelected}" Value="True">
                                                                        <Setter Property="BorderThickness" Value="2" />
                                                                        <Setter Property="Background" Value="#DBEAFE" />
                                                                        <Setter Property="BorderBrush" Value="#2563EB" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Meta}" FontSize="11" Foreground="#444" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Meta2}" FontSize="11" Foreground="#444" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding StartText}" FontSize="11" Foreground="#444" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding EndText}" FontSize="11" Foreground="#444" TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="1" Grid.Column="2" BorderBrush="#D0D0D0" BorderThickness="1" Background="#FFFFFF" Padding="8">
                <ListBox ItemsSource="{Binding SelectedJobLines}" BorderThickness="0" Background="#FFFFFF" />
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Margin="0,8,0,0" Foreground="#555" Text="提示：Ctrl+點擊可多選；單擊為單選；點空白處可清除選取；右鍵可推移到指定日期時段。" />
    </Grid>
</Window>


